{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/app", "destination": "/apps/app/index.html" },
    { "source": "/app/:path*", "destination": "/apps/app/index.html" },
    { "source": "/building", "destination": "/apps/building/index.html" },
    { "source": "/", "destination": "/apps/landing/index.html" }
  ]
}
